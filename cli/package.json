{
  "name": "raspberry-cli",
  "version": "1.0.3",
  "description": "CLI tool for managing and building Raspberry framework projects.",
  "type": "module",
  "bin": {
    "raspberry": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean"
  },

  "keywords": [
    "raspberry",
    "cli",
    "framework",
    "flutter",
    "flutter-like-framework",
    "react",
    "svelte",
    "vue",
    "angular",
    "preact",
    "web"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "fs-extra": "^11.3.2",
    "inquirer": "^12.10.0",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  }
}

